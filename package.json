{
  "name": "@s-h-a-d-o-w/speech-recorder",
  "version": "2.1.1",
  "description": "A node.js library for streaming audio and speech from the microphone.",
  "main": "src/index.js",
  "repository": "https://github.com/serenadeai/speech-recorder",
  "author": "Serenade",
  "license": "MIT",
  "gypfile": true,
  "binary": {
    "napi_versions": [
      10
    ]
  },
  "scripts": {
    "build": "bash build.sh",
    "clean": "rm -rf build prebuilds lib/build lib/install",
    "install": "prebuild-install -r napi || node-gyp rebuild"
  },
  "dependencies": {
    "bindings": "^1.5.0",
    "node-addon-api": "^8.8.0",
    "prebuild-install": "^7.1.3"
  },
  "devDependencies": {
    "node-gyp": "^13.0.0",
    "prebuild": "^13.0.1",
    "wavefile": "^11.0.0"
  }
}
